#!/bin/bash

# ====================================
# Config
# ====================================
LOG_FILE="/var/log/lscwp-update-ip.log"
LOG_LOCK="/tmp/lscwp-log-$$.lock"
RESULT_DIR="/tmp/lscwp-results-$$"
RAM_PER_JOB_MB=200

# ====================================
# Colors
# ====================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ====================================
# Log function
# ====================================
log() {
    echo -e "$1"
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" \
        "$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')" \
        | flock "$LOG_LOCK" tee -a "$LOG_FILE" >/dev/null
}

# ====================================
# Cleanup
# ====================================
cleanup() {
    rm -rf "$RESULT_DIR"
    rm -f  "$LOG_LOCK"
}
trap cleanup EXIT

mkdir -p "$RESULT_DIR"

# ====================================
# คำนวณ MAX_JOBS
# ====================================
CPU_CORES=$(nproc)
TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
MAX_JOBS_BY_RAM=$(( TOTAL_RAM_MB / RAM_PER_JOB_MB ))

if [ "$CPU_CORES" -lt "$MAX_JOBS_BY_RAM" ]; then
    MAX_JOBS=$CPU_CORES
else
    MAX_JOBS=$MAX_JOBS_BY_RAM
fi
[ "$MAX_JOBS" -lt 1 ]  && MAX_JOBS=1
[ "$MAX_JOBS" -gt 20 ] && MAX_JOBS=20

# ====================================
# Header
# ====================================
log ""
log "${BOLD}======================================${NC}"
log "${BOLD}  LITESPEED UPDATE SERVER IP${NC}"
log "${BOLD}======================================${NC}"
log " ${DIM}CPU Cores  :${NC} ${CYAN}${CPU_CORES} Core${NC}"
log " ${DIM}Total RAM  :${NC} ${CYAN}${TOTAL_RAM_MB} MB${NC}"
log " ${DIM}Max Jobs   :${NC} ${CYAN}${MAX_JOBS}${NC}"
log "${DIM}--------------------------------------${NC}"

# ====================================
# ดึง Server IP — fallback 3 แหล่ง, เก็บค่าครั้งเดียว
# ====================================
log " กำลังดึง Server IP..."

SERVER_IP=""
for SOURCE in "https://ifconfig.me" "https://api.ipify.org" "https://ipinfo.io/ip"; do
    IP=$(curl -4 -s --max-time 10 "$SOURCE" 2>/dev/null | tr -d '[:space:]')
    if [[ "$IP" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        SERVER_IP="$IP"
        break
    fi
done

if [ -z "$SERVER_IP" ]; then
    log "${RED}❌ ERROR: ดึง Server IP ไม่ได้ — หยุดทำงาน${NC}"
    exit 1
fi

log " ${DIM}Server IP  :${NC} ${BOLD}${GREEN}${SERVER_IP}${NC}  ${DIM}← เก็บค่าแล้ว ใช้กับทุกเว็บ${NC}"
log "${BOLD}======================================${NC}"

# ====================================
# ฟังก์ชัน parse IP จาก output ของ wp litespeed-option get
# output มีหน้าตา: "server_ip:\n15.235.140.227"
# ต้อง grep เอา IP จริงๆ ออกมา
# ====================================
parse_ip() {
    grep -E "^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$" | head -1 | tr -d '[:space:]'
}

# ====================================
# Worker — รันใน subprocess
# ====================================
process_site() {
    local dir="$1"
    local SERVER_IP="$2"
    local LOG_FILE="$3"
    local LOG_LOCK="$4"
    local RESULT_DIR="$5"
    local IDX="$6"
    local TOTAL="$7"

    local RED='\033[0;31m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local CYAN='\033[0;36m'
    local BOLD='\033[1m'
    local DIM='\033[2m'
    local NC='\033[0m'

    # ชื่อเว็บ: /home/USER/public_html/DOMAIN/ → USER/DOMAIN
    local SITE
    SITE=$(awk -F'/' '{print $3"/"$5}' <<< "$dir")
    local UNIQUE="${IDX}_${BASHPID}"
    local PFX="${DIM}[${IDX}/${TOTAL}]${NC}"

    _log() {
        echo -e "$1"
        printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" \
            "$(echo -e "$1" | sed 's/\x1b\[[0-9;]*m//g')" \
            | flock "$LOG_LOCK" tee -a "$LOG_FILE" >/dev/null
    }

    _mark() { touch "${RESULT_DIR}/${1}_${UNIQUE}"; }

    parse_ip() {
        grep -E "^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$" | head -1 | tr -d '[:space:]'
    }

    # --- ตรวจ Plugin ติดตั้งหรือไม่ ---
    if ! wp --path="$dir" plugin is-installed litespeed-cache \
            --allow-root >/dev/null 2>&1; then
        _log "${PFX} ${YELLOW}⏭  SKIP${NC}  ${DIM}ไม่มี Plugin${NC}  ${CYAN}${SITE}${NC}"
        _mark "skip"; return
    fi

    # --- ตรวจ Plugin เปิดอยู่ไหม ---
    if ! wp --path="$dir" plugin is-active litespeed-cache \
            --allow-root >/dev/null 2>&1; then
        _log "${PFX} ${YELLOW}⏭  SKIP${NC}  ${DIM}Plugin ถูกปิด${NC}  ${CYAN}${SITE}${NC}"
        _mark "skip"; return
    fi

    # --- อ่าน IP ปัจจุบัน ---
    local OLD_IP
    OLD_IP=$(wp --path="$dir" litespeed-option get server_ip \
        --allow-root 2>/dev/null | parse_ip)

    # --- IP เหมือนเดิม → ข้ามทันที ---
    if [ "$OLD_IP" = "$SERVER_IP" ]; then
        _log "${PFX} ${DIM}⏩  SAME   IP ตรงกันแล้ว ข้าม${NC}  ${CYAN}${SITE}${NC}  ${DIM}(${OLD_IP})${NC}"
        _mark "same"; return
    fi

    # --- อัพเดต IP ---
    if wp --path="$dir" litespeed-option set server_ip "$SERVER_IP" \
            --allow-root >/dev/null 2>&1; then

        # ยืนยันค่าที่เขียนจริง
        local NEW_IP
        NEW_IP=$(wp --path="$dir" litespeed-option get server_ip \
            --allow-root 2>/dev/null | parse_ip)

        if [ "$NEW_IP" = "$SERVER_IP" ]; then
            local OLD_D="${OLD_IP:-ว่าง}"
            _log "${PFX} ${GREEN}✅ OK${NC}     ${CYAN}${SITE}${NC}  ${DIM}${OLD_D} →${NC} ${GREEN}${NEW_IP}${NC}"
            _mark "success"
        else
            _log "${PFX} ${RED}❌ VERIFY${NC}  ${CYAN}${SITE}${NC}  ${DIM}(ได้ = ${NEW_IP:-ว่าง})${NC}"
            _mark "failed"
        fi
    else
        _log "${PFX} ${RED}❌ FAILED${NC}  ${CYAN}${SITE}${NC}"
        _mark "failed"
    fi
}

export -f process_site

# ====================================
# หา WordPress ทั้งหมด
# ====================================
log " กำลังค้นหา WordPress..."

DIRS=()
for dir in /home/*/public_html/*/; do
    [ -f "${dir}wp-config.php" ] && DIRS+=("$dir")
done

TOTAL=${#DIRS[@]}

if [ "$TOTAL" -eq 0 ]; then
    log "${RED}❌ ไม่พบ WordPress ใดๆ${NC}"
    exit 1
fi

log " ${DIM}พบ WordPress :${NC} ${BOLD}${TOTAL} เว็บ${NC}"
log "${BOLD}======================================${NC}"

# ====================================
# Parallel Sliding Window
# ====================================
declare -a PIDS=()
IDX=0

for dir in "${DIRS[@]}"; do
    (( IDX++ ))
    process_site "$dir" "$SERVER_IP" "$LOG_FILE" "$LOG_LOCK" \
                 "$RESULT_DIR" "$IDX" "$TOTAL" &
    PIDS+=($!)

    if [ "${#PIDS[@]}" -ge "$MAX_JOBS" ]; then
        wait "${PIDS[0]}"
        PIDS=("${PIDS[@]:1}")
    fi
done

for pid in "${PIDS[@]}"; do
    wait "$pid"
done

# ====================================
# สรุปผล
# ====================================
CNT_OK=$(find   "$RESULT_DIR" -name "success_*" 2>/dev/null | wc -l)
CNT_SAME=$(find "$RESULT_DIR" -name "same_*"    2>/dev/null | wc -l)
CNT_SKIP=$(find "$RESULT_DIR" -name "skip_*"    2>/dev/null | wc -l)
CNT_FAIL=$(find "$RESULT_DIR" -name "failed_*"  2>/dev/null | wc -l)

log ""
log "${BOLD}======================================${NC}"
log "${BOLD}  สรุปผล${NC}"
log "${BOLD}--------------------------------------${NC}"
log " ${GREEN}✅ อัพเดตสำเร็จ${NC}       : ${BOLD}${CNT_OK}${NC} เว็บ"
log " ${DIM}⏩  IP เดิม (ข้าม)${NC}    : ${CNT_SAME} เว็บ"
log " ${YELLOW}⏭  ข้าม (ไม่มี/ปิด)${NC}  : ${CNT_SKIP} เว็บ"
log " ${RED}❌ ล้มเหลว${NC}             : ${BOLD}${CNT_FAIL}${NC} เว็บ"
log "${BOLD}--------------------------------------${NC}"
log " รวมทั้งหมด             : ${TOTAL} เว็บ"
log " Log อยู่ที่             : ${DIM}${LOG_FILE}${NC}"
log "${BOLD}======================================${NC}"
log ""
